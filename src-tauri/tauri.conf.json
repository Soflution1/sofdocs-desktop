{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
	"productName": "SofDocs",
	"version": "0.1.0",
	"identifier": "com.soflution.sofdocs",
	"build": {
		"frontendDist": "./frontend-dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "",
		"beforeBuildCommand": ""
	},
	"app": {
		"windows": [
			{
				"title": "SofDocs",
				"width": 1280,
				"height": 800,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"dialog": {},
		"fs": {
			"scope": ["**"]
		}
	}
}
